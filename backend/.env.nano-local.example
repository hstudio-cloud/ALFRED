NANO_LLM_PROVIDER=self_hosted
NANO_VOICE_PROVIDER=self_hosted

NANO_LLM_URL=http://127.0.0.1:8009/generate
NANO_LLM_TIMEOUT=60
NANO_LLM_AUTH_TOKEN=

NANO_STT_URL=http://127.0.0.1:8010/transcribe
NANO_TTS_URL=http://127.0.0.1:8011/speak

OLLAMA_BASE_URL=http://127.0.0.1:11434/v1
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_API_KEY=ollama

NANO_STT_MODEL=base
NANO_STT_DEVICE=cpu
NANO_STT_COMPUTE_TYPE=int8

# TTS local funcional no Windows:
NANO_TTS_BACKEND=pyttsx3

# MiniMax TTS opcional via microservico Node/Express.
VOICE_PROVIDER=minimax
VOICE_PORT=8012
VOICE_CORS_ORIGINS=http://localhost:3000
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_VOICE_ID=English_expressive_narrator
MINIMAX_VOICE_SPEED=1
MINIMAX_VOICE_VOLUME=1
MINIMAX_VOICE_PITCH=0

# Opcional para usar Coqui depois:
NANO_TTS_MODEL=tts_models/pt/cv/vits
NANO_TTS_LANGUAGE=pt
NANO_TTS_SPEAKER=
NANO_TTS_SPEAKER_WAV=
