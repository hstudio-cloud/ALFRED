MONGO_URL=
DB_NAME=nano
CORS_ORIGINS=*

# Opcional para respostas melhores no beta.
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4o-mini
OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE_NAME=ash
OPENAI_VOICE_INSTRUCTIONS=Fale em portugues do Brasil com voz encorpada, sofisticada e diccao clara.
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_PROMPT=Transcreva em portugues do Brasil com ortografia correta e termos financeiros do Nano IA.

# Producao beta: usar modo automatico e fallback de voz no navegador.
NANO_LLM_PROVIDER=auto
NANO_VOICE_PROVIDER=auto

# WhatsApp Cloud API (Meta)
WHATSAPP_PROVIDER=meta_cloud
WHATSAPP_PROVIDER_TOKEN=
WHATSAPP_META_PHONE_NUMBER_ID=
WHATSAPP_META_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_WEBHOOK_SECRET=

# Stripe Billing (mensalidades SaaS)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_DEFAULT_PRICE_ID=
STRIPE_PRICE_ID_STARTER=
STRIPE_PRICE_ID_PRO=
STRIPE_CHECKOUT_SUCCESS_URL=https://frontend-six-woad-fz102b0vy8.vercel.app/billing?checkout=success&session_id={CHECKOUT_SESSION_ID}
STRIPE_CHECKOUT_CANCEL_URL=https://frontend-six-woad-fz102b0vy8.vercel.app/billing?checkout=cancelled
STRIPE_CUSTOMER_PORTAL_RETURN_URL=https://frontend-six-woad-fz102b0vy8.vercel.app/billing
ASAAS_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_API_KEY=
ASAAS_WEBHOOK_TOKEN=
BILLING_DEFAULT_AMOUNT=49.90
BILLING_PLAN_STARTER_AMOUNT=49.90
BILLING_PLAN_PRO_AMOUNT=99.90

# MiniMax TTS opcional. Use em um servico Node separado para /api/voice/speak.
VOICE_PROVIDER=minimax
VOICE_PORT=8012
VOICE_CORS_ORIGINS=https://SEU-FRONTEND.onrender.com
MINIMAX_API_KEY=
MINIMAX_GROUP_ID=
MINIMAX_TTS_MODEL=speech-02-hd
MINIMAX_VOICE_ID=English_expressive_narrator
MINIMAX_VOICE_SPEED=1
MINIMAX_VOICE_VOLUME=1
MINIMAX_VOICE_PITCH=0
