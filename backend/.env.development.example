MONGO_URL=
DB_NAME=nano
CORS_ORIGINS=http://localhost:3000

# Desenvolvimento local com Ollama como backend principal do LLM.
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama
OPENAI_TEXT_MODEL=qwen3:8b

# Se quiser testar o mesmo fluxo de producao localmente, troque para OpenRouter:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=
# OPENAI_TEXT_MODEL=openrouter/free
# OPENROUTER_APP_NAME=Nano IA
# OPENROUTER_SITE_URL=http://localhost:3000

OPENAI_VOICE_MODEL=gpt-4o-mini-tts
OPENAI_VOICE_NAME=ash
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TRANSCRIBE_PROMPT=Transcreva em portugues do Brasil com ortografia correta e termos financeiros do Nano IA.

NANO_LLM_PROVIDER=auto
NANO_VOICE_PROVIDER=auto
